# Agentic AI Project Environment Variables

# ==========================================
# Database Configuration (Postgres)
# ==========================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=agent_state

# ==========================================
# Database Configuration (Oracle 23ai)
# ==========================================
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=FREEPDB1
ORACLE_USER=system
ORACLE_PASSWORD=AdminPassword123



# ==========================================
# AI Models (OpenRouter)
# ==========================================
OPENROUTER_API_KEY=your_openrouter_api_key

# ==========================================
# ServiceNow Integration
# ==========================================
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com/
SERVICENOW_USERNAME=your_username
SERVICENOW_PASSWORD=your_password

# ==========================================
# Confluence Cloud
# ==========================================
CONFLUENCE_BASE_URL=https://your-org.atlassian.net
CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY
CONFLUENCE_ORG_ID=your_org_id
CONFLUENCE_API_KEY=your_api_key
CONFLUENCE_USER_EMAIL=your_email@example.com
